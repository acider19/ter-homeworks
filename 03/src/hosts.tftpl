[webservers]

%{~ for ws in webservers ~}

${ws.name}   ansible_host=${ws.network_interface[0].nat_ip_address} fqdn=${ws.fqdn}
%{~ endfor }

[databases]

%{~ for j in databases ~}

${j["name"]}   ansible_host=${j["network_interface"][0]["nat_ip_address"]} fqdn=${j["fqdn"]}
%{~ endfor }

[storage]

${storage.name}   ansible_host=${storage.network_interface[0].nat_ip_address} fqdn=${storage.fqdn}
